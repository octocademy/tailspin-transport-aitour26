{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Tailspin: Run App",
      "type": "node",
      "request": "launch",
      "noDebug": true,
      "preLaunchTask": "Tailspin: Prepare app",
      "program": "${workspaceFolder}/node_modules/next/dist/bin/next",
      "args": ["dev"],
      "cwd": "${workspaceFolder}",
      "skipFiles": ["<node_internals>/**"],
      "serverReadyAction": {
        "action": "openExternally",
        "killOnServerStop": true,
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s"
      }
    }
  ]
}
